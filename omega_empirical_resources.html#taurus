<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omega Scalar Coherence Identity — Empirical Resources</title>
    <style>
        :root {
            --gold: #c8a04e;
            --dark: #0a0a1a;
            --panel: #1a1a2e;
            --green: #00ff88;
            --red: #ff4444;
            --orange: #ffaa00;
            --cyan: #00ffff;
            --text: #e0e0e0;
            --muted: #888888;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--dark);
            color: var(--text);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: linear-gradient(180deg, var(--panel) 0%, var(--dark) 100%);
            border-bottom: 2px solid var(--gold);
            padding: 2rem 1rem;
            text-align: center;
        }

        .header h1 {
            color: var(--gold);
            font-size: 2rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .header .subtitle {
            color: var(--muted);
            font-size: 1rem;
            font-style: italic;
        }

        .header .author {
            color: var(--green);
            font-family: monospace;
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        /* Navigation */
        .nav {
            display: flex;
            justify-content: center;
            gap: 1rem;
            padding: 1rem;
            background: var(--panel);
            border-bottom: 1px solid var(--gold);
            flex-wrap: wrap;
        }

        .nav a {
            color: var(--gold);
            text-decoration: none;
            padding: 0.5rem 1rem;
            border: 1px solid var(--gold);
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .nav a:hover {
            background: var(--gold);
            color: var(--dark);
        }

        /* Main Content */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }

        .section {
            background: var(--panel);
            border: 1px solid var(--gold);
            border-radius: 8px;
            margin-bottom: 2rem;
            overflow: hidden;
        }

        .section-header {
            background: linear-gradient(90deg, var(--gold) 0%, transparent 100%);
            color: var(--dark);
            padding: 1rem 1.5rem;
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .section-body {
            padding: 1.5rem;
        }

        /* Resource Cards */
        .resource-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 1.5rem;
        }

        .resource-card {
            background: var(--dark);
            border: 1px solid var(--muted);
            border-radius: 6px;
            padding: 1.5rem;
            transition: all 0.3s ease;
        }

        .resource-card:hover {
            border-color: var(--gold);
            box-shadow: 0 0 15px rgba(200, 160, 78, 0.2);
        }

        .resource-card .card-title {
            color: var(--gold);
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .resource-card .card-title .icon {
            font-size: 1.2rem;
        }

        .resource-card .card-desc {
            color: var(--muted);
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        .resource-card .card-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }

        .resource-card .card-meta .tag {
            background: var(--panel);
            color: var(--green);
            padding: 0.2rem 0.6rem;
            border-radius: 3px;
            font-size: 0.75rem;
            font-family: monospace;
        }

        .resource-card .card-meta .status {
            font-size: 0.75rem;
            font-weight: 600;
        }

        .resource-card .card-meta .status.available {
            color: var(--green);
        }

        .resource-card .card-meta .status.limited {
            color: var(--orange);
        }

        .resource-card .card-link {
            display: inline-block;
            color: var(--cyan);
            text-decoration: none;
            font-size: 0.85rem;
            font-family: monospace;
            word-break: break-all;
        }

        .resource-card .card-link:hover {
            text-decoration: underline;
        }

        /* Data Table */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        .data-table th {
            background: var(--gold);
            color: var(--dark);
            padding: 0.75rem;
            text-align: left;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 1px;
        }

        .data-table td {
            padding: 0.75rem;
            border-bottom: 1px solid var(--muted);
            color: var(--text);
        }

        .data-table tr:hover td {
            background: rgba(200, 160, 78, 0.05);
        }

        .data-table .param-name {
            color: var(--gold);
            font-weight: 600;
            font-family: monospace;
        }

        .data-table .exact {
            color: var(--green);
            font-weight: 600;
        }

        .data-table .empirical {
            color: var(--orange);
            font-weight: 600;
        }

        .data-table .derived {
            color: var(--cyan);
            font-weight: 600;
        }

        /* Equation Block */
        .equation-block {
            background: var(--dark);
            border-left: 3px solid var(--gold);
            padding: 1.5rem;
            margin: 1rem 0;
            font-family: 'Courier New', monospace;
            font-size: 0.95rem;
            line-height: 1.8;
            overflow-x: auto;
        }

        .equation-block .eq-label {
            color: var(--gold);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        /* Falsification Panel */
        .falsification-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1rem;
        }

        .fals-card {
            background: var(--dark);
            border: 1px solid var(--red);
            border-radius: 6px;
            padding: 1rem;
        }

        .fals-card.tier1 {
            border-color: var(--red);
        }

        .fals-card.tier2 {
            border-color: var(--orange);
        }

        .fals-card .fals-code {
            color: var(--red);
            font-weight: 700;
            font-family: monospace;
            font-size: 1.1rem;
        }

        .fals-card.tier2 .fals-code {
            color: var(--orange);
        }

        .fals-card .fals-test {
            color: var(--text);
            font-size: 0.9rem;
            margin: 0.5rem 0;
        }

        .fals-card .fals-threshold {
            color: var(--muted);
            font-size: 0.8rem;
            font-family: monospace;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 2rem;
            border-top: 1px solid var(--gold);
            color: var(--muted);
            font-size: 0.85rem;
        }

        .footer .m-lock {
            color: var(--gold);
            font-family: monospace;
            font-weight: 700;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.4rem;
            }
            .resource-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
