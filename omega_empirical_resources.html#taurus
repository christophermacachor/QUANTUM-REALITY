        <!-- SECTION 1: ERA5 Atmospheric Reanalysis -->
        <section class="section" id="era5">
            <div class="section-header">ERA5 Atmospheric Reanalysis — Primary Data Source</div>
            <div class="section-body">
                <div class="resource-grid">

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🌍</span> ERA5 Single Levels</div>
                        <div class="card-desc">Hourly data on single levels from 1940 to present. Covers April 30, 1967. 0.25 degree resolution.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://cds.climate.copernicus.eu/datasets/reanalysis-era5-single-levels?tab=overview" target="_blank">cds.climate.copernicus.eu/datasets/reanalysis-era5-single-levels</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">📊</span> ERA5 Pressure Levels</div>
                        <div class="card-desc">37 pressure levels for vorticity, divergence, geopotential. Required for |zeta| computation.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://cds.climate.copernicus.eu/datasets/reanalysis-era5-pressure-levels?tab=overview" target="_blank">cds.climate.copernicus.eu/datasets/reanalysis-era5-pressure-levels</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🔑</span> CDS API Access</div>
                        <div class="card-desc">Programmatic download via Python API. Requires free registration and API key.</div>
                        <div class="card-meta">
                            <span class="tag">API</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://cds.climate.copernicus.eu/how-to-api" target="_blank">cds.climate.copernicus.eu/how-to-api</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">📖</span> ERA5 Documentation</div>
                        <div class="card-desc">Parameter database, variable definitions, and data format specifications.</div>
                        <div class="card-meta">
                            <span class="tag">DOCS</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://confluence.ecmwf.int/display/CKB/ERA5%3A+data+documentation" target="_blank">confluence.ecmwf.int/display/CKB/ERA5</a>
                    </div>

                </div>
            </div>
        </section>

        <!-- SECTION 2: NASA Earthdata -->
        <section class="section" id="nasa">
            <div class="section-header">NASA Earthdata — Satellite & Remote Sensing</div>
            <div class="section-body">
                <div class="resource-grid">

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🛰️</span> NASA Earthdata Portal</div>
                        <div class="card-desc">Gateway to satellite, radar, and atmospheric datasets. Free Earthdata Login required.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://www.earthdata.nasa.gov" target="_blank">www.earthdata.nasa.gov</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🌪️</span> NASA Tornado Data</div>
                        <div class="card-desc">TRMM/GPM precipitation radar, GOES-R lightning, MODIS atmospheric profiles for tornado research.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://www.earthdata.nasa.gov/topics/atmosphere/tornadoes" target="_blank">www.earthdata.nasa.gov/topics/atmosphere/tornadoes</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">📡</span> OPERA DISP-S1 Static</div>
                        <div class="card-desc">Surface displacement from Sentinel-1. Static radar geometry layers. Released July 2026.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://search.asf.alaska.edu" target="_blank">search.asf.alaska.edu</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🌐</span> Giovanni Visualization</div>
                        <div class="card-desc">Online visualization and analysis tool for NASA satellite data. No download required.</div>
                        <div class="card-meta">
                            <span class="tag">WEB</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://giovanni.gsfc.nasa.gov" target="_blank">giovanni.gsfc.nasa.gov</a>
                    </div>

                </div>
            </div>
        </section>

        <!-- SECTION 3: Copernicus -->
        <section class="section" id="copernicus">
            <div class="section-header">Copernicus Programme — European Earth Observation</div>
            <div class="section-body">
                <div class="resource-grid">

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🛰️</span> Copernicus Climate Data Store</div>
                        <div class="card-desc">Primary portal for ERA5, seasonal forecasts, and climate reanalysis products.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://cds.climate.copernicus.eu" target="_blank">cds.climate.copernicus.eu</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">📡</span> Sentinel-1 SAR Data</div>
                        <div class="card-desc">Synthetic Aperture Radar for surface displacement. C-band, all-weather, day-night imaging.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://scihub.copernicus.eu" target="_blank">scihub.copernicus.eu</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🌊</span> Copernicus Marine Service</div>
                        <div class="card-desc">Ocean monitoring data: sea surface temperature, currents, salinity.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://marine.copernicus.eu" target="_blank">marine.copernicus.eu</a>
                    </div>

                </div>
            </div>
        </section>

        <!-- SECTION 4: NOAA/NWS Historical Data -->
        <section class="section" id="noaa">
            <div class="section-header">NOAA / National Weather Service — Historical Severe Weather</div>
            <div class="section-body">
                <div class="resource-grid">

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🌪️</span> Storm Events Database</div>
                        <div class="card-desc">Historical tornado, hail, and wind events. April 21, 1967 Oak Lawn-Belvidere outbreak documented.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://www.ncdc.noaa.gov/stormevents/" target="_blank">www.ncdc.noaa.gov/stormevents</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">📊</span> NCEI Climate Data</div>
                        <div class="card-desc">Historical surface weather observations. Daily data for Chicago, April 1967.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://www.ncei.noaa.gov/access/search/data-search" target="_blank">www.ncei.noaa.gov/access/search/data-search</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">🗺️</span> NCEP/NCAR Reanalysis I</div>
                        <div class="card-desc">Atmospheric reanalysis 1948-present. 2.5 degree grid, 6-hourly. Covers April 1967.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status available">AVAILABLE</span>
                        </div>
                        <a class="card-link" href="https://psl.noaa.gov/data/gridded/data.ncep.reanalysis.html" target="_blank">psl.noaa.gov/data/gridded/data.ncep.reanalysis</a>
                    </div>

                    <div class="resource-card">
                        <div class="card-title"><span class="icon">📡</span> NEXRAD Level II Archive</div>
                        <div class="card-desc">Doppler radar data from 1990s-present. For modern tornado J(r_c) validation.</div>
                        <div class="card-meta">
                            <span class="tag">FREE</span>
                            <span class="status limited">1990+ ONLY</span>
                        </div>
                        <a class="card-link" href="https://www.ncei.noaa.gov/access/radar-products" target="_blank">www.ncei.noaa.gov/access/radar-products</a>
                    </div>

                </div>
            </div>
        </section>

        <!-- SECTION 5: Core Parameters -->
        <section class="section" id="parameters">
            <div class="section-header">Core Parameters — Absolute Quantification</div>
            <div class="section-body">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Parameter</th>
                            <th>Value</th>
                            <th>Derivation</th>
                            <th>Type</th>
                            <th>Uncertainty</th>
                            <th>Data Source</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="param-name">L* = 24</td>
                            <td class="exact">24</td>
                            <td>2*log10(10^12)</td>
                            <td class="exact">EXACT</td>
                            <td class="exact">±0</td>
                            <td>Arithmetic</td>
                        </tr>
                        <tr>
                            <td class="param-name">x_c</td>
