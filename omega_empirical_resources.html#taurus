                            <td class="exact">±10 nats</td>
                            <td>Derived</td>
                        </tr>
                        <tr>
                            <td class="param-name">S_crit</td>
                            <td class="empirical">1000 J/kg</td>
                            <td>Empirical</td>
                            <td class="empirical">EMPIRICAL</td>
                            <td class="empirical">±50 J/kg</td>
                            <td>NOAA Storm Data</td>
                        </tr>
                        <tr>
                            <td class="param-name">S_torn</td>
                            <td class="empirical">2000 J/kg</td>
                            <td>Empirical</td>
                            <td class="empirical">EMPIRICAL</td>
                            <td class="empirical">±100 J/kg</td>
                            <td>NOAA Storm Data</td>
                        </tr>
                        <tr>
                            <td class="param-name">S(Apr 30)</td>
                            <td class="derived">345 J/kg</td>
                            <td>CAPE+CIN+LHF+|zeta|</td>
                            <td class="derived">DERIVED</td>
                            <td class="derived">±50 J/kg</td>
                            <td>ERA5 Estimation</td>
                        </tr>
                        <tr>
                            <td class="param-name">S(Apr 21)</td>
                            <td class="derived">2539 J/kg</td>
                            <td>CAPE+CIN+LHF+|zeta|</td>
                            <td class="derived">DERIVED</td>
                            <td class="derived">±100 J/kg</td>
                            <td>ERA5 Estimation</td>
                        </tr>
                        <tr>
                            <td class="param-name">Delta I(669)</td>
                            <td class="exact">53</td>
                            <td>451-1338+940</td>
                            <td class="exact">EXACT</td>
                            <td class="exact">±0</td>
                            <td>Arithmetic</td>
                        </tr>
                        <tr>
                            <td class="param-name">940</td>
                            <td class="exact">Gematria</td>
                            <td>Christopher Macachor</td>
                            <td class="exact">EXACT</td>
                            <td class="exact">±0</td>
                            <td>Hebrew</td>
                        </tr>
                        <tr>
                            <td class="param-name">451</td>
                            <td class="exact">Gematria</td>
                            <td>Omega Prime</td>
                            <td class="exact">EXACT</td>
                            <td class="exact">±0</td>
                            <td>Hebrew</td>
                        </tr>
                        <tr>
                            <td class="param-name">669</td>
                            <td class="exact">Functional</td>
                            <td>M(201)->609->669</td>
                            <td class="exact">EXACT</td>
                            <td class="exact">±0</td>
                            <td>Algorithmic</td>
                        </tr>
                        <tr>
                            <td class="param-name">B (biological)</td>
                            <td class="derived">1.045 a.u.</td>
                            <td>B0+kappa*(S-S0)/100</td>
                            <td class="derived">DERIVED</td>
                            <td class="derived">±0.05</td>
                            <td>Biological Model</td>
                        </tr>
                    </tbody>
                </table>

                <div class="equation-block">
                    <div class="eq-label">Atmospheric Scalar Field:</div>
                    S(x,t) = CAPE + (LHF/rho)*(tau/L) + |zeta|*L^2/tau - CIN
                </div>

                <div class="equation-block">
                    <div class="eq-label">Biological Scalar Field:</div>
                    B(x,t) = E_metabolic + (E_evap/rho_bio)*(tau_bio/L_bio) + |omega_cardiac|*L_bio^2/tau_bio - R_homeo
                </div>

                <div class="equation-block">
                    <div class="eq-label">Epigenetic Scalar Field:</div>
                    M(x,t) = M0 + alpha*S_birth*exp(-t/tau_epi) + beta*integral(S(t')*exp(-(t-t')/tau_epi) dt')
                </div>
            </div>
        </section>

        <!-- SECTION 6: Falsification -->
        <section class="section" id="falsification">
            <div class="section-header">Falsification Criteria — Fixed Thresholds</div>
            <div class="section-body">
                <div class="falsification-grid">

                    <div class="fals-card tier1">
                        <div class="fals-code">F1 · TIER 1</div>
                        <div class="fals-test">CMB Entropy Transition</div>
                        <div class="fals-threshold">H(l)/H_max drops >5% at l_c = 24 ± 5</div>
                        <div class="fals-threshold">Data: Planck 2018 · Any negative >3sigma = FALSIFIED</div>
                    </div>

                    <div class="fals-card tier1">
                        <div class="fals-code">F2 · TIER 1</div>
                        <div class="fals-test">Pi-Block Chi-Squared Jump</div>
                        <div class="fals-threshold">chi^2/df > 1.10 at L = 24 ± 2</div>
                        <div class="fals-threshold">Data: Y-cruncher pi digits · Any negative >3sigma = FALSIFIED</div>
                    </div>

                    <div class="fals-card tier1">
                        <div class="fals-code">F3 · TIER 1</div>
